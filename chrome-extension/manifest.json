{
  "manifest_version": 3,
  "name": "PhysioApp NotebookLM Extractor",
  "version": "1.7.0",
  "description": "Extract flashcards, quizzes, and mind maps from NotebookLM for PhysioApp",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://notebooklm.google.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon-48.png"
    }
  },
  "web_accessible_resources": [{
    "resources": ["notebooklm_physioapp_extractor.js"],
    "matches": ["https://notebooklm.google.com/*"]
  }],
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
